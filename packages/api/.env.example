# Database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pa_dev"

# Server configuration
PORT=3001
NODE_ENV=development

# Session secret (generate a random string for production)
SESSION_SECRET="your-super-secret-session-key-change-in-production"

# CORS origin for web UI
CORS_ORIGIN="http://localhost:3000"

# Babblo app database (read-only connection)
BABBLO_DATABASE_URL="postgresql://user:password@host:5432/babblo"

# Resend email delivery
RESEND_API_KEY="re_your_key_here"

# Anthropic API (used by email template translation build script)
ANTHROPIC_API_KEY="sk-ant-your_key_here"
